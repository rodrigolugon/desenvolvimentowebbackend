<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Academia</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Academia</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.IsInRole("Aluno")) {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Aluno" asp-action="MeuTreino">Meu Treino</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Aluno" asp-action="EditarMeusDados">Meus Dados</a>
                            </li>
                        }

                        @if (User.IsInRole("Personal")) {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Personal" asp-action="MeusAlunos">Meus Alunos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Treino" asp-action="Create">Criar Treino</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Treino" asp-action="Index">Editar Treino</a>
                            </li>
                        }

                        @if (User.IsInRole("Admin")) {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="GerenciarAlunos">Gerenciar Alunos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="GerenciarPersonais">Gerenciar Personais</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="GerenciarExercicios">Gerenciar Exercícios</a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav">
                        @if (User.Identity!.IsAuthenticated) {
                            <li class="nav-item">
                                <span class="nav-link text-muted">Olá, @User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                    <button type="submit" class="nav-link btn btn-link">Sair</button>
                                </form>
                            </li>
                        }
                        else {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Registrar</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="RegisterPersonal">Sou Personal</a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="RegisterAluno">Sou Aluno</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
