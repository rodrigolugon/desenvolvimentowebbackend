@{
    ViewData["Title"] = "Registrar Aluno";
}

<h1>Registrar como Aluno</h1>
<hr />

<div class="row">
    <div class="col-md-4">
        <form method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group mb-3">
                <label>Nome</label>
                <input name="nome" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label>E-Mail</label>
                <input name="email" type="email" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label>Senha</label>
                <input name="senha" type="password" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label>Personal</label>
                <select name="personalId" class="form-control">
                    <option value="">-- Selecione um Personal --</option>
                    @foreach (var personal in ViewBag.Personals ?? new List<Academia.Models.Personal>()) {
                        <option value="@personal.PersonalID">@personal.Nome</option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Registrar</button>
        </form>
    </div>
</div>