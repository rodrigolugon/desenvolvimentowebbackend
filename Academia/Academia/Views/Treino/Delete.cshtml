@model Academia.Models.Treino
@{
    ViewData["Title"] = "Excluir Treino";
}

<h1>Excluir Treino</h1>
<hr />

<div class="alert alert-danger">
    Tem certeza que deseja excluir este treino?
</div>

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Personal</dt>
            <dd class="col-sm-8">@Model.Personal?.Nome</dd>

            <dt class="col-sm-4">Aluno</dt>
            <dd class="col-sm-8">@Model.Aluno?.Nome</dd>

            <dt class="col-sm-4">Data</dt>
            <dd class="col-sm-8">@Model.Data.ToString("dd/MM/yyyy")</dd>

            <dt class="col-sm-4">Hora</dt>
            <dd class="col-sm-8">@Model.Hora</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="TreinoID" />
    <input type="submit" value="Confirmar Exclusão" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>